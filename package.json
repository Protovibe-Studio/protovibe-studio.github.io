{
  "name": "protovibe-project-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "concat:all": "node scripts/concat.js all",
    "concat:plugins": "node scripts/concat.js plugins",
    "concat:no-ui": "node scripts/concat.js no-ui",
    "postinstall": "pnpm --dir plugins/protovibe install && node -e \"require('fs').rmSync('plugins/protovibe/dist',{recursive:true,force:true})\" && pnpm --dir plugins/protovibe run build",
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build && vite build --ssr src/entry-server.tsx --outDir dist/server && node scripts/prerender.mjs",
    "preview": "vite preview",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@iconify/react": "^6.0.2",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "babel": "^5.8.38",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-protovibe": "link:./plugins/protovibe",
    "wrangler": "latest"
  }
}
